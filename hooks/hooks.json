{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/tff-dependency-check.js",
            "timeout": 30000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/tff-context-monitor.js",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
