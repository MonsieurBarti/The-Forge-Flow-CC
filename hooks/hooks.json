[
  {
    "event": "SessionStart",
    "hooks": [
      {
        "type": "command",
        "command": "node hooks/tff-dependency-check.js",
        "timeout": 30000
      }
    ]
  },
  {
    "event": "PostToolUse",
    "hooks": [
      {
        "type": "command",
        "command": "node hooks/tff-context-monitor.js",
        "timeout": 5000
      }
    ]
  }
]
