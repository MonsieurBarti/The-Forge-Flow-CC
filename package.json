{
  "name": "@the-forge-flow/tff-cc",
  "version": "0.9.1",
  "description": "Autonomous coding agent orchestrator for Claude Code",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "tsc -p tsconfig.build.json && node scripts/add-cli-shebang.cjs",
    "build": "tsc -p tsconfig.build.json && bun run scripts/add-cli-shebang.ts && cp native/*.node dist/infrastructure/adapters/sqlite/",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --fix src/ tests/",
    "format": "biome format --write src/ tests/"
  },
  "keywords": [
    "claude-code",
    "plannotator",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MonsieurBarti/The-Forge-Flow-CC.git"
  },
  "license": "MIT",
  "author": "MonsieurBarti",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.8.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/proper-lockfile": "^4.1.4",
    "fast-check": "^4.6.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
